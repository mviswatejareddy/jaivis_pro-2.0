from __future__ import annotations

import json
import re
from pathlib import Path

import torch
import torch.nn as nn
from torch.utils.data import DataLoader, TensorDataset


ROOT = Path(__file__).resolve().parents[3]
DATA_PATH = ROOT / "src" / "jarvis" / "data" / "intents.json"
MODEL_PATH = ROOT / "models" / "intent_transformer.pt"

MAX_LEN = 20
EMBED_DIM = 96
NUM_HEADS = 4
NUM_LAYERS = 2
FFN_DIM = 192
BATCH_SIZE = 8
EPOCHS = 40
LR = 2e-3


def tokenize(text: str) -> list[str]:
    return re.findall(r"[a-z0-9_=\[\]-]+", text.lower())


def build_vocab(texts: list[str]) -> dict[str, int]:
    vocab = {"<pad>": 0, "<unk>": 1}
    for t in texts:
        for tok in tokenize(t):
            if tok not in vocab:
                vocab[tok] = len(vocab)
    return vocab


def encode_text(text: str, vocab: dict[str, int], max_len: int) -> list[int]:
    ids = [vocab.get(tok, vocab["<unk>"]) for tok in tokenize(text)][:max_len]
    if len(ids) < max_len:
        ids.extend([vocab["<pad>"]] * (max_len - len(ids)))
    return ids


class TransformerIntentClassifier(nn.Module):
    def __init__(self, vocab_size: int, num_classes: int) -> None:
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, EMBED_DIM, padding_idx=0)
        encoder_layer = nn.TransformerEncoderLayer(
            d_model=EMBED_DIM,
            nhead=NUM_HEADS,
            dim_feedforward=FFN_DIM,
            batch_first=True,
            dropout=0.2,
            activation="gelu",
        )
        self.encoder = nn.TransformerEncoder(encoder_layer, num_layers=NUM_LAYERS)
        self.norm = nn.LayerNorm(EMBED_DIM)
        self.fc = nn.Linear(EMBED_DIM, num_classes)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        emb = self.embedding(x)
        h = self.encoder(emb)
        pooled = h.mean(dim=1)
        pooled = self.norm(pooled)
        return self.fc(pooled)


def load_data() -> tuple[list[str], list[str]]:
    with DATA_PATH.open("r", encoding="utf-8") as f:
        data = json.load(f)
    texts: list[str] = []
    labels: list[str] = []
    for intent in data["intents"]:
        for p in intent["patterns"]:
            texts.append(p)
            labels.append(intent["tag"])
    return texts, labels


def train() -> None:
    texts, labels_raw = load_data()
    labels = sorted(set(labels_raw))
    label_to_idx = {x: i for i, x in enumerate(labels)}

    vocab = build_vocab(texts)
    x = [encode_text(t, vocab, MAX_LEN) for t in texts]
    y = [label_to_idx[t] for t in labels_raw]

    ds = TensorDataset(torch.tensor(x, dtype=torch.long), torch.tensor(y, dtype=torch.long))
    dl = DataLoader(ds, batch_size=BATCH_SIZE, shuffle=True)

    model = TransformerIntentClassifier(vocab_size=len(vocab), num_classes=len(labels))
    optimizer = torch.optim.AdamW(model.parameters(), lr=LR)
    criterion = nn.CrossEntropyLoss()

    model.train()
    for epoch in range(EPOCHS):
        running = 0.0
        for xb, yb in dl:
            optimizer.zero_grad()
            logits = model(xb)
            loss = criterion(logits, yb)
            loss.backward()
            optimizer.step()
            running += loss.item()
        if (epoch + 1) % 10 == 0:
            print(f"epoch={epoch+1}/{EPOCHS} loss={running/len(dl):.4f}")

    MODEL_PATH.parent.mkdir(parents=True, exist_ok=True)
    torch.save(
        {"state_dict": model.state_dict(), "vocab": vocab, "labels": labels, "max_len": MAX_LEN},
        MODEL_PATH,
    )
    print(f"Transformer model saved to: {MODEL_PATH}")


if __name__ == "__main__":
    train()
